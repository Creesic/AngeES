// Regression fixture: exercises the 1.14 vehicle/transmission "flex" + brake
// inputs backported to this build. Compiled by ScriptCompilerTests to verify
// the new inputs parse and resolve. Not shipped as a selectable engine.

import "engine_sim.mr"
import "engines/atg-video-1/02_kohler_ch750.mr"

units units()

private node flex_transmission {
    alias output __out: transmission;

    transmission transmission(
        max_clutch_torque: 35 * units.lb_ft,
        simulate_flex: true,
        clutch_stiffness: 1000 * units.Nm,
        clutch_damping: 10.0,
        max_clutch_flex: 5 * units.deg,
        limit_clutch_flex: true
    )

    transmission.add_gear(1.0)
}

private node flex_vehicle {
    alias output __out:
        vehicle(
            mass: 563 * units.lb,
            drag_coefficient: 0.1,
            cross_sectional_area: (20 * units.inch) * (47 * units.inch),
            diff_ratio: 2.353,
            tire_radius: 8.5 * units.inch,
            rolling_resistance: 10000 * units.N,
            simulate_flex: true,
            stiffness: 2000 * units.Nm,
            damping: 20.0,
            max_flex: 10 * units.deg,
            limit_flex: true,
            max_brake_force: 5000 * units.N
        );
}

public node main {
    set_engine(kohler_ch750())
    set_transmission(flex_transmission())
    set_vehicle(flex_vehicle())
}

main()
